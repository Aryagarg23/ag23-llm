# Copy to .env. ALL optional — set keys only for providers you have; the rest are skipped.
# `python -m ag23_llm providers` shows what's configured.
# Free tiers / signup: see github.com/cheahjs/free-llm-api-resources
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
CODESTRAL_API_KEY=
NVIDIA_API_KEY=
HF_TOKEN=
GITHUB_MODELS_TOKEN=
COHERE_API_KEY=
SAMBANOVA_API_KEY=
SCALEWAY_API_KEY=
HYPERBOLIC_API_KEY=
# Cloudflare Workers AI needs BOTH the token and the account id (used in the URL).
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
# Local vLLM needs no key; used when reachable at http://localhost:8000/v1
